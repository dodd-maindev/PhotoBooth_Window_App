<Window x:Class="Photobooth.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Photobooth.Desktop"
        xmlns:converters="clr-namespace:Photobooth.Desktop.Converters"
        mc:Ignorable="d"
        Title="Joli Films - Chọn template"
        Icon="pack://application:,,,/asset/Logo/joli-film-logo.png"
        Width="1600"
        Height="1000"
        MinWidth="1280"
        MinHeight="800"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="#170507"
        FontFamily="Bahnschrift"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <LinearGradientBrush x:Key="WindowGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#170507" Offset="0.00" />
            <GradientStop Color="#2A090C" Offset="0.52" />
            <GradientStop Color="#3A0D10" Offset="1.00" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="HeaderGradientBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#240709" Offset="0.00" />
            <GradientStop Color="#4A1014" Offset="1.00" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="FooterGradientBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#22080A" Offset="0.00" />
            <GradientStop Color="#471216" Offset="1.00" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CardGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#2A0F12" Offset="0.00" />
            <GradientStop Color="#3D1418" Offset="1.00" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonGradientBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#B98A4A" Offset="0.00" />
            <GradientStop Color="#E3BF77" Offset="1.00" />
        </LinearGradientBrush>

        <SolidColorBrush x:Key="PanelBrush" Color="#331114" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#7A4730" />
        <SolidColorBrush x:Key="AccentBrush" Color="#E8C786" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#5A241A" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFF6E8" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#D8BFA1" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="Button" x:Key="FilterButtonStyle">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#3C1519" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="RootBorder" Property="Background" Value="#5A241A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#2F0F13" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="ActionButtonStyle">
            <Setter Property="Foreground" Value="#170507" />
            <Setter Property="Background" Value="{StaticResource ButtonGradientBrush}" />
            <Setter Property="BorderBrush" Value="#8A6236" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#8A6236" BlurRadius="8" ShadowDepth="2" Opacity="0.5" Direction="270" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActionRoot" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="ActionRoot" Property="Opacity" Value="0.92" />
                                <Setter TargetName="ActionRoot" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#E8C786" BlurRadius="14" ShadowDepth="3" Opacity="0.6" Direction="270" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ActionRoot" Property="Opacity" Value="0.78" />
                                <Setter TargetName="ActionRoot" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#8A6236" BlurRadius="4" ShadowDepth="1" Opacity="0.4" Direction="270" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ActionRoot" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="Background" Value="{StaticResource CardGradientBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style TargetType="TextBlock" x:Key="CaptionTextStyle">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Storyboard x:Key="LoadingRotationStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="LoadingSpinner"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="0" To="360" Duration="0:0:1.1" />
        </Storyboard>

        <Storyboard x:Key="FilterSpinnerStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="FilterSpinner"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="0" To="360" Duration="0:0:1.1" />
        </Storyboard>

        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>

    <Grid Background="{StaticResource WindowGradientBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderGradientBrush}" Padding="13,4" BorderBrush="#7A4730" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid VerticalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                            Width="58"
                            Height="58"
                            Margin="0,0,10,0"
                            Background="#2A0E12"
                            Padding="4"
                            CornerRadius="14"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1"
                            ClipToBounds="True"
                            VerticalAlignment="Center">
                        <Image Source="asset/Logo/joli-film-logo.png" Stretch="Uniform" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="JOLI FILM - SELFBOOTH HANOI" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="34 ngõ 58 Đào Tấn, Ba Đình , Hà Nội" Style="{StaticResource CaptionTextStyle}" Foreground="#E2CAA6" FontSize="11" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CustomerName, StringFormat=Khách: {0}}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right" />
                    <TextBlock Text="{Binding SelectedFilter.DisplayName, StringFormat=Filter: {0}}" FontSize="11" Foreground="#D8BFA1" HorizontalAlignment="Right" />
                    <TextBlock Text="{Binding CameraStatusMessage}" Style="{StaticResource CaptionTextStyle}" HorizontalAlignment="Right" FontSize="10" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="12,10,12,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.30*" />
                <ColumnDefinition Width="1.30*" />
                <ColumnDefinition Width="0.70*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Live camera preview" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="Xem trước trực tiếp từ máy ảnh" Style="{StaticResource CaptionTextStyle}" />
                    </StackPanel>
                    <Border Grid.Row="1" Background="#220B0D" CornerRadius="0" BorderBrush="#7A4730" BorderThickness="1" ClipToBounds="True">
                        <Image Source="{Binding CurrentCameraImage}" Stretch="Uniform" SnapsToDevicePixels="True" RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Processed preview" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="Ảnh sau khi áp dụng filter từ Python" Style="{StaticResource CaptionTextStyle}" />
                    </StackPanel>
                    <Border Grid.Row="1" Background="#220B0D" CornerRadius="0" BorderBrush="#7A4730" BorderThickness="1" ClipToBounds="True">
                        <Grid>
                            <Image Source="{Binding CurrentProcessedImage}" Stretch="Uniform" SnapsToDevicePixels="True" RenderOptions.BitmapScalingMode="HighQuality" />

                            <Grid x:Name="FilterLoadingOverlay"
                                  Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                                  Background="#CC000000">
                                <Grid.Triggers>
                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                        <BeginStoryboard Storyboard="{StaticResource FilterSpinnerStoryboard}" />
                                    </EventTrigger>
                                </Grid.Triggers>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid Width="60" Height="60" HorizontalAlignment="Center">
                                        <Ellipse Stroke="{StaticResource AccentBrush}" StrokeThickness="5" Opacity="0.22" />
                                        <Ellipse x:Name="FilterSpinner"
                                                 Stroke="{StaticResource AccentBrush}"
                                                 StrokeThickness="5"
                                                 StrokeDashArray="1.8 1.2"
                                                 StrokeStartLineCap="Round"
                                                 StrokeEndLineCap="Round"
                                                 RenderTransformOrigin="0.5,0.5">
                                            <Ellipse.RenderTransform>
                                                <RotateTransform Angle="0" />
                                            </Ellipse.RenderTransform>
                                        </Ellipse>
                                    </Grid>
                                    <TextBlock Text="Đang áp dụng filter..."
                                               FontSize="12"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,10,0,0" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="10,0,0,0">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock Text="Filters" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="Chọn filter cho ảnh mới đến" Style="{StaticResource CaptionTextStyle}" />
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Filters}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource FilterButtonStyle}"
                                            Width="Auto"
                                            Margin="0,0,0,12"
                                            Command="{Binding DataContext.SelectFilterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" FontSize="15" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Description}" Style="{StaticResource CaptionTextStyle}" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource FooterGradientBrush}" Padding="10,7" BorderBrush="#7A4730" BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Style="{StaticResource ActionButtonStyle}" Content="Capture" Command="{Binding CaptureCommand}" Margin="0,0,8,0" Padding="16,7" />
                    <Button Style="{StaticResource ActionButtonStyle}" Content="Print 1" Command="{Binding PrintSingleCommand}" Margin="0,0,8,0" Padding="16,7" />
                    <Button Style="{StaticResource ActionButtonStyle}" Content="Print 4" Command="{Binding PrintFourCommand}" Margin="0,0,8,0" Padding="16,7" />
                    <Button Style="{StaticResource ActionButtonStyle}" Content="Clear" Command="{Binding ClearHistoryCommand}" Margin="0,0,8,0" Padding="16,7" />
                    <Button Style="{StaticResource ActionButtonStyle}" Content="KẾT THÚC" Command="{Binding EndSessionCommand}" Padding="20,7" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding LastErrorMessage}" Style="{StaticResource CaptionTextStyle}" Foreground="#FFB3B3" />
                </StackPanel>
            </DockPanel>
        </Border>

                <Grid Background="#B3000000"
                      Visibility="Collapsed">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Width="120" Height="120" HorizontalAlignment="Center">
                    <Ellipse Stroke="{StaticResource AccentBrush}" StrokeThickness="10" Opacity="0.22" />
                    <Ellipse x:Name="LoadingSpinner"
                             Stroke="{StaticResource AccentBrush}"
                             StrokeThickness="10"
                             StrokeDashArray="1.8 1.2"
                             StrokeStartLineCap="Round"
                             StrokeEndLineCap="Round"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform Angle="0" />
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </Grid>
                <TextBlock Text="Đang xử lý ảnh..." FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,18,0,0" />
            </StackPanel>
            <Grid.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard Storyboard="{StaticResource LoadingRotationStoryboard}" />
                </EventTrigger>
            </Grid.Triggers>
        </Grid>
    </Grid>
</Window>
