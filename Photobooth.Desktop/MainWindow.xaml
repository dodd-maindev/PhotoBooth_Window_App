<Window x:Class="Photobooth.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Photobooth.Desktop"
        xmlns:converters="clr-namespace:Photobooth.Desktop.Converters"
        xmlns:models="clr-namespace:Photobooth.Desktop.Models"
        mc:Ignorable="d"
        Title="Joli Films - Photobooth"
        Icon="pack://application:,,,/asset/Logo/joli-film-logo.png"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="#0A0406"
        FontFamily="Segoe UI"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <!-- Converters -->
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:FilterEqualityConverter x:Key="FilterEqualityConverter"/>
        <converters:BoolToVisibilityInverseConverter x:Key="BoolToVisibilityInverseConverter"/>
        <converters:UiModeToVisibilityConverter x:Key="UiModeToVisibilityConverter"/>

        <!-- Color Palette -->
        <SolidColorBrush x:Key="BackgroundPrimary" Color="#0A0406"/>
        <SolidColorBrush x:Key="BackgroundSecondary" Color="#1A0A0D"/>
        <SolidColorBrush x:Key="BackgroundCard" Color="#2A1215"/>
        <SolidColorBrush x:Key="BackgroundPanel" Color="#1E0C0F"/>

        <SolidColorBrush x:Key="AccentGold" Color="#FFD700"/>
        <SolidColorBrush x:Key="AccentGoldLight" Color="#FFED8A"/>
        <SolidColorBrush x:Key="AccentGoldDark" Color="#B8860B"/>
        <SolidColorBrush x:Key="AccentGoldMuted" Color="#8B7355"/>

        <SolidColorBrush x:Key="GlowGold" Color="#FFD700"/>
        <SolidColorBrush x:Key="GlowGoldSoft" Color="#AA8B00"/>

        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#C9B896"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8B7355"/>

        <SolidColorBrush x:Key="BorderGold" Color="#4A3520"/>
        <SolidColorBrush x:Key="BorderGoldLight" Color="#6B5A3A"/>

        <!-- Gradient Brushes -->
        <LinearGradientBrush x:Key="BackgroundGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0A0406" Offset="0.0"/>
            <GradientStop Color="#1A080C" Offset="0.5"/>
            <GradientStop Color="#120508" Offset="1.0"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#150A0D" Offset="0.0"/>
            <GradientStop Color="#1E1013" Offset="0.5"/>
            <GradientStop Color="#150A0D" Offset="1.0"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonGoldGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFD700" Offset="0.0"/>
            <GradientStop Color="#DAA520" Offset="0.5"/>
            <GradientStop Color="#B8860B" Offset="1.0"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CardBorderGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#3A2A15" Offset="0.0"/>
            <GradientStop Color="#5A4530" Offset="0.5"/>
            <GradientStop Color="#3A2A15" Offset="1.0"/>
        </LinearGradientBrush>

        <!-- Glow Effects -->
        <DropShadowEffect x:Key="GoldGlowEffectSoft" Color="#FFD700" BlurRadius="10" ShadowDepth="0" Direction="0" Opacity="0.4"/>

        <!-- Base TextBlock Style -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- Card Border Style -->
        <Style x:Key="GlowingCardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BackgroundCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderGradient}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#FFD700" BlurRadius="15" ShadowDepth="0" Opacity="0.2" Direction="0"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Filter Button Style -->
        <Style x:Key="FilterButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="{StaticResource BackgroundPanel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderGold}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="FilterBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#FFD700" BlurRadius="8" ShadowDepth="0" Opacity="0" Direction="0"/>
                            </Border.Effect>
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FilterBorder" Property="BorderBrush" Value="{StaticResource AccentGold}"/>
                                <Setter TargetName="FilterBorder" Property="Background" Value="#2A1A1D"/>
                                <Setter TargetName="FilterBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#FFD700" BlurRadius="15" ShadowDepth="0" Opacity="0.4" Direction="0"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FilterBorder" Property="Background" Value="{StaticResource BackgroundPanel}"/>
                                <Setter TargetName="FilterBorder" Property="BorderBrush" Value="{StaticResource AccentGoldMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Action Button Style -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#0A0406"/>
            <Setter Property="Background" Value="{StaticResource ButtonGoldGradient}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentGoldDark}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#FFD700" BlurRadius="10" ShadowDepth="2" Opacity="0.5" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                            TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActionBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#FFD700" BlurRadius="20" ShadowDepth="3" Opacity="0.8" Direction="270"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ActionBorder" Property="BorderBrush" Value="{StaticResource AccentGoldLight}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ActionBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#B8860B" BlurRadius="5" ShadowDepth="1" Opacity="0.4" Direction="270"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ActionBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ActionBorder" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- End Session Button Style (Red accent) -->
        <Style x:Key="EndSessionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#DC3545" Offset="0.0"/>
                        <GradientStop Color="#B02A37" Offset="1.0"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#8B2030"/>
        </Style>

        <!-- Caption Text Style -->
        <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Section Title Style -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentGoldLight}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Loading Animation -->
        <Storyboard x:Key="LoadingRotationStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="LoadingSpinner"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="0" To="360" Duration="0:0:1.1"/>
        </Storyboard>

        <Storyboard x:Key="FilterSpinnerStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="FilterSpinner"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="0" To="360" Duration="0:0:1.1"/>
        </Storyboard>
    </Window.Resources>

    <!-- Main Background -->
    <Grid Background="{StaticResource BackgroundGradient}">
        <!-- ==================== LANDSCAPE LAYOUT ==================== -->
        <Grid x:Name="LandscapeLayout"
              Visibility="{Binding UiModeSetting, Converter={StaticResource UiModeToVisibilityConverter}, ConverterParameter=Landscape}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Background="{StaticResource HeaderGradient}"
                    BorderBrush="{StaticResource BorderGold}" BorderThickness="0,0,0,2"
                    Padding="20,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <Border Grid.Column="0" Width="70" Height="70" Margin="0,0,16,0" CornerRadius="16"
                            Effect="{StaticResource GoldGlowEffectSoft}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1A1015" Offset="0"/>
                                <GradientStop Color="#0A0406" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Image Source="asset/Logo/joli-film-logo.png" Stretch="Fill"/>
                    </Border>

                    <!-- Brand Info -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Loc[BrandName]}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentGoldLight}"/>
                            <TextBlock Text=" - " FontSize="22" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding Loc[AppSubtitle]}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentGoldLight}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Loc[Address]}" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Right Info -->
                    <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding Loc[Customer]}" FontSize="13" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text=": " FontSize="13" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding CustomerName}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AccentGoldLight}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                            <TextBlock Text="{Binding Loc[Filter]}" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text=": " FontSize="11" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding SelectedFilter.DisplayName}" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                            <Image Source="asset/Right_Icon/Right_Icon.png" Width="70" Height="70" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- MAIN CONTENT -->
            <Grid Grid.Row="1" Margin="16,12,16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.6*"/>
                    <ColumnDefinition Width="1.6*"/>
                    <ColumnDefinition Width="0.5*"/>
                </Grid.ColumnDefinitions>

                <!-- Camera Preview -->
                <Border Grid.Column="0" Style="{StaticResource GlowingCardBorder}" Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{Binding Loc[LivePreview]}" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="{Binding Loc[LivePreviewDesc]}" Style="{StaticResource CaptionTextStyle}"/>
                            </StackPanel>
                        </Grid>
                        <Border Grid.Row="1" Background="#050203" CornerRadius="8" BorderBrush="{StaticResource BorderGoldLight}" BorderThickness="1" ClipToBounds="True">
                            <Grid>
                                <Image Source="{Binding CurrentCameraImage}" Stretch="Uniform" SnapsToDevicePixels="True" RenderOptions.BitmapScalingMode="HighQuality"/>
                                <Border CornerRadius="8" BorderThickness="3" Opacity="0.3">
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FFD700" Offset="0"/>
                                            <GradientStop Color="#FFA500" Offset="0.5"/>
                                            <GradientStop Color="#FFD700" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Processed Preview -->
                <Border Grid.Column="1" Style="{StaticResource GlowingCardBorder}" Margin="10,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{Binding Loc[ProcessedPreview]}" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="{Binding Loc[ProcessedPreviewDesc]}" Style="{StaticResource CaptionTextStyle}"/>
                            </StackPanel>
                        </Grid>
                        <Border Grid.Row="1" Background="#050203" CornerRadius="8" BorderBrush="{StaticResource BorderGoldLight}" BorderThickness="1" ClipToBounds="True">
                            <Grid>
                                <Image Source="{Binding CurrentProcessedImage}" Stretch="Uniform" SnapsToDevicePixels="True" RenderOptions.BitmapScalingMode="HighQuality"/>
                                <Grid Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" Background="#CC0A0406">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Grid Width="70" Height="70">
                                            <Ellipse Stroke="{StaticResource AccentGoldDark}" StrokeThickness="4" Opacity="0.3"/>
                                            <Ellipse x:Name="FilterSpinner" Stroke="{StaticResource AccentGoldLight}" StrokeThickness="4" StrokeDashArray="1.5 1" RenderTransformOrigin="0.5,0.5">
                                                <Ellipse.RenderTransform><RotateTransform Angle="0"/></Ellipse.RenderTransform>
                                            </Ellipse>
                                        </Grid>
                                        <TextBlock Text="Đang xử lý filter..." FontSize="13" Foreground="{StaticResource AccentGoldLight}" HorizontalAlignment="Center" Margin="0,14,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Filter Panel -->
                <Border Grid.Column="2" Style="{StaticResource GlowingCardBorder}" Margin="10,0,0,0">
                    <DockPanel LastChildFill="True">
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="{Binding Loc[Filters]}" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="{Binding Loc[FilterDesc]}" Style="{StaticResource CaptionTextStyle}"/>
                            </StackPanel>
                        </Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Filters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.SelectFilterCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource FilterButtonStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <MultiBinding Converter="{StaticResource FilterEqualityConverter}">
                                                                    <Binding Path="DataContext.SelectedFilter" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                    <Binding/>
                                                                </MultiBinding>
                                                            </DataTrigger.Binding>
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentGold}"/>
                                                            <Setter Property="Background" Value="#2A1A1D"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="36" Height="36" Background="{StaticResource BackgroundPanel}" CornerRadius="6" Margin="0,0,12,0">
                                                    <Path Data="{Binding IconData}" Fill="{StaticResource AccentGoldMuted}" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Description}" Style="{StaticResource CaptionTextStyle}" Margin="0,3,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- FOOTER -->
            <Border Grid.Row="2" Background="{StaticResource HeaderGradient}" BorderBrush="{StaticResource BorderGold}" BorderThickness="0,2,0,0" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Margin="0,0,10,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource AccentGoldMuted}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource AccentGold}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock Text="{Binding LastErrorMessage}" Style="{StaticResource CaptionTextStyle}" Foreground="#FF6B6B" Margin="20,4,0,0" Visibility="{Binding LastErrorMessage, Converter={StaticResource BoolToVisibilityInverseConverter}}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding CaptureCommand}" Margin="0,0,10,0" Padding="20,10">
                            <TextBlock Text="{Binding Loc[Capture]}"/>
                        </Button>
                        <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding ClearHistoryCommand}" Margin="0,0,10,0" Padding="14,10">
                            <TextBlock Text="{Binding Loc[Delete]}"/>
                        </Button>
                        <Button Style="{StaticResource EndSessionButtonStyle}" Command="{Binding EndSessionCommand}" Padding="18,10">
                            <TextBlock Text="{Binding Loc[EndSession]}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ==================== PORTRAIT LAYOUT ==================== -->
        <Grid x:Name="PortraitLayout"
              Visibility="{Binding UiModeSetting, Converter={StaticResource UiModeToVisibilityConverter}, ConverterParameter=Portrait}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="1.6*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER (Compact) -->
            <Border Grid.Row="0" Background="{StaticResource HeaderGradient}"
                    BorderBrush="{StaticResource BorderGold}" BorderThickness="0,0,0,2"
                    Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo (Smaller) -->
                    <Border Grid.Column="0" Width="45" Height="45" Margin="0,0,12,0" CornerRadius="10"
                            Effect="{StaticResource GoldGlowEffectSoft}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1A1015" Offset="0"/>
                                <GradientStop Color="#0A0406" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Image Source="asset/Logo/joli-film-logo.png" Stretch="Fill"/>
                    </Border>

                    <!-- Brand Info (Compact) -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Loc[BrandName]}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentGoldLight}"/>
                            <TextBlock Text=" - " FontSize="16" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding Loc[AppSubtitle]}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentGoldLight}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Loc[Address]}" FontSize="9" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="{Binding CustomerName}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AccentGoldLight}"/>
                            <TextBlock Text=" | " FontSize="9" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding Loc[Filter]}" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text=": " FontSize="9" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding SelectedFilter.DisplayName}" FontSize="9" Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Camera Status (Compact) -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="asset/Right_Icon/Right_Icon.png" Width="65" Height="65" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- LIVE PREVIEW (Large Area) -->
            <Border Grid.Row="1" Margin="12,10,12,6" Background="{StaticResource BackgroundCard}" BorderBrush="{StaticResource CardBorderGradient}" BorderThickness="2" CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,10,12,8">
                        <TextBlock Text="{Binding Loc[LivePreviewPortrait]}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AccentGoldLight}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#050203" CornerRadius="8" BorderBrush="{StaticResource BorderGoldLight}" BorderThickness="1" ClipToBounds="True" Margin="8,0,8,8">
                        <Grid>
                            <Image Source="{Binding CurrentCameraImage}" Stretch="Uniform" SnapsToDevicePixels="True" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <Border CornerRadius="8" BorderThickness="3" Opacity="0.3">
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FFD700" Offset="0"/>
                                        <GradientStop Color="#FFA500" Offset="0.5"/>
                                        <GradientStop Color="#FFD700" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- CAPTURED PHOTO (Medium Area) -->
            <Border Grid.Row="2" Margin="12,6,12,6" Background="{StaticResource BackgroundCard}" BorderBrush="{StaticResource CardBorderGradient}" BorderThickness="2" CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,10,12,8">
                        <TextBlock Text="{Binding Loc[CapturedPhoto]}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AccentGoldLight}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#050203" CornerRadius="8" BorderBrush="{StaticResource BorderGoldLight}" BorderThickness="1" ClipToBounds="True" Margin="8,0,8,8">
                        <Grid>
                            <Image Source="{Binding CurrentProcessedImage}" Stretch="Uniform" SnapsToDevicePixels="True" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <Grid Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" Background="#CC0A0406">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid Width="50" Height="50">
                                        <Ellipse Stroke="{StaticResource AccentGoldDark}" StrokeThickness="3" Opacity="0.3"/>
                                        <Ellipse Stroke="{StaticResource AccentGoldLight}" StrokeThickness="3" StrokeDashArray="1.5 1" RenderTransformOrigin="0.5,0.5">
                                            <Ellipse.RenderTransform><RotateTransform Angle="0"/></Ellipse.RenderTransform>
                                        </Ellipse>
                                    </Grid>
                                    <TextBlock Text="{Binding Loc[ProcessingFilter]}" FontSize="11" Foreground="{StaticResource AccentGoldLight}" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- FILTER BUTTONS (Compact Row) -->
            <Border Grid.Row="3" Margin="12,6,12,6" Background="{StaticResource BackgroundCard}" BorderBrush="{StaticResource CardBorderGradient}" BorderThickness="2" CornerRadius="12" Padding="10,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4,0,0,8">
                        <TextBlock Text="{Binding Loc[SelectFilter]}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AccentGoldLight}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Filters}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.SelectFilterCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" MinWidth="90" Margin="0,0,8,8">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource FilterButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource FilterEqualityConverter}">
                                                            <Binding Path="DataContext.SelectedFilter" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                            <Binding/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentGold}"/>
                                                    <Setter Property="Background" Value="#2A1A1D"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{Binding IconData}" Fill="{StaticResource AccentGoldMuted}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding DisplayName}" FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- ACTION BUTTONS (Footer) -->
            <Border Grid.Row="4" Background="{StaticResource HeaderGradient}" BorderBrush="{StaticResource BorderGold}" BorderThickness="0,2,0,0" Padding="12,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource AccentGoldMuted}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource AccentGold}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <UniformGrid Grid.Row="1" Columns="3" Margin="0,8,0,0">
                        <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding ClearHistoryCommand}" Margin="4,0" Padding="8,10">
                            <TextBlock Text="{Binding Loc[Delete]}" FontSize="12"/>
                        </Button>
                        <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding CaptureCommand}" Margin="4,0" Padding="8,10">
                            <TextBlock Text="{Binding Loc[Capture]}" FontSize="12"/>
                        </Button>
                        <Button Style="{StaticResource EndSessionButtonStyle}" Command="{Binding EndSessionCommand}" Margin="4,0" Padding="8,10">
                            <TextBlock Text="{Binding Loc[EndSession]}" FontSize="12"/>
                        </Button>
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- ==================== GLOBAL LOADING OVERLAY ==================== -->
        <Grid Background="#E60A0406" Visibility="Collapsed">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Width="100" Height="100" HorizontalAlignment="Center">
                    <Ellipse Stroke="{StaticResource AccentGoldDark}" StrokeThickness="6" Opacity="0.3"/>
                    <Ellipse x:Name="LoadingSpinner" Stroke="{StaticResource AccentGoldLight}" StrokeThickness="6" StrokeDashArray="1.5 1" RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform><RotateTransform Angle="0"/></Ellipse.RenderTransform>
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#FFD700" BlurRadius="15" ShadowDepth="0" Opacity="0.7"/>
                        </Ellipse.Effect>
                    </Ellipse>
                </Grid>
                <TextBlock Text="{Binding Loc[LoadingTitle]}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource AccentGoldLight}" HorizontalAlignment="Center" Margin="0,16,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
