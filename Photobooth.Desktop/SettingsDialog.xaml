<Window x:Class="Photobooth.Desktop.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Cài đặt - Photobooth"
        Width="620"
        Height="600"
        MinWidth="620"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#170507"
        FontFamily="Bahnschrift">
    <Window.Resources>
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#240709" Offset="0.00" />
            <GradientStop Color="#4A1014" Offset="1.00" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="AccentBrush" Color="#E8C786" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFF6E8" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#D8BFA1" />
        <SolidColorBrush x:Key="PanelBrush" Color="#2A0F12" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#7A4730" />
        <LinearGradientBrush x:Key="ButtonGradientBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#B98A4A" Offset="0.00" />
            <GradientStop Color="#E3BF77" Offset="1.00" />
        </LinearGradientBrush>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A080B" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1A080B" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style TargetType="Button" x:Key="PrimaryButtonStyle">
            <Setter Property="Foreground" Value="#170507" />
            <Setter Property="Background" Value="{StaticResource ButtonGradientBrush}" />
            <Setter Property="BorderBrush" Value="#8A6236" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="SecondaryButtonStyle">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2A0F12" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style TargetType="TextBlock" x:Key="CaptionTextStyle">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}" Padding="16,12" BorderBrush="#7A4730" BorderThickness="0,0,0,1">
            <TextBlock Text="CÀI ĐẶT PHOTOBOOTH" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>
                <GroupBox Header="Loại máy ảnh">
                    <StackPanel>
                        <Label Content="Chọn loại máy ảnh bạn đang sử dụng:" />
                        <ComboBox x:Name="CameraTypeComboBox" Margin="0,6,0,0" Width="300" HorizontalAlignment="Left"
                                  SelectionChanged="CameraTypeComboBox_SelectionChanged">
                            <ComboBoxItem Content="Canon (EOS Webcam Utility)" Tag="Canon" />
                            <ComboBoxItem Content="Fujifilm (Tether App + X Webcam)" Tag="Fuji" />
                        </ComboBox>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Thư mục lưu ảnh">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <Label Content="Thư mục Fuji Save (Tether App gửi ảnh vào đây):" />
                                <TextBox x:Name="FujiSaveFolderTextBox" Margin="0,4,0,0" />
                                <Label Content="Thư mục Watch (app theo dõi ảnh mới):" Margin="0,10,0,0" />
                                <TextBox x:Name="FujiWatchFolderTextBox" Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                        <Label Content="Thư mục xử lý (ảnh đang xử lý):" Margin="0,10,0,0" />
                        <TextBox x:Name="ProcessingFolderTextBox" Margin="0,4,0,0" />
                        <Label Content="Thư mục xuất (ảnh đã xử lý xong):" Margin="0,10,0,0" />
                        <TextBox x:Name="OutputFolderTextBox" Margin="0,4,0,0" />
                        <Label Content="Thư mục log:" Margin="0,10,0,0" />
                        <TextBox x:Name="LogFolderTextBox" Margin="0,4,0,0" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Canon - Cài đặt webcam">
                    <StackPanel>
                        <Label Content="Tên camera ưu tiên (ví dụ: EOS Webcam Utility):" />
                        <TextBox x:Name="CanonCameraNameTextBox" Margin="0,4,0,0" />
                        <Label Content="Nếu không tìm thấy theo tên, dùng chỉ mục (0, 1, 2...):" Margin="0,8,0,0" />
                        <TextBox x:Name="CanonCameraIndexTextBox" Margin="0,4,0,0" Width="100" HorizontalAlignment="Left" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Fujifilm - Cài đặt webcam">
                    <StackPanel>
                        <Label Content="Tên camera Fujifilm X Webcam (để trống = tự động chọn):" />
                        <TextBox x:Name="FujiCameraNameTextBox" Margin="0,4,0,0" />
                        <Label Content="Chỉ mục thiết bị webcam (0, 1, 2...; -1 = tự động):" Margin="0,8,0,0" />
                        <TextBox x:Name="FujiWebcamIndexTextBox" Margin="0,4,0,0" Width="100" HorizontalAlignment="Left" />
                        <TextBlock Text="Dùng chỉ mục nếu app không tìm đúng webcam FUJIFILM." Foreground="#888" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="API - Python Service">
                    <StackPanel>
                        <Label Content="API Base URL:" />
                        <TextBox x:Name="ApiBaseUrlTextBox" Margin="0,4,0,0" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <Label Content="Timeout (giây):" />
                                <TextBox x:Name="ApiTimeoutTextBox" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,8,0">
                                <Label Content="Số lần thử lại:" />
                                <TextBox x:Name="ApiRetriesTextBox" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                <Label Content="Độ trễ retry (ms):" />
                                <TextBox x:Name="RetryDelayTextBox" Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="In ấn">
                    <CheckBox x:Name="AutoPrintCheckBox" Content="Tự động in ảnh sau khi xử lý" Foreground="{StaticResource TextPrimaryBrush}" />
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{StaticResource HeaderBrush}" Padding="16,12" BorderBrush="#7A4730" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Thay đổi sẽ được lưu vào appsettings.json" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Hủy" Style="{StaticResource SecondaryButtonStyle}" Click="CancelButton_Click" Margin="0,0,10,0" />
                <Button Grid.Column="2" Content="Lưu cài đặt" Style="{StaticResource PrimaryButtonStyle}" Click="SaveButton_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
