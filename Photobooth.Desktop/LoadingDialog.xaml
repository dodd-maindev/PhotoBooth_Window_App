<Window x:Class="Photobooth.Desktop.LoadingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đang tải..."
        Width="400"
        Height="280"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False">

    <Window.Resources>
        <Storyboard x:Key="LoadingRotation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="LoadingSpinner"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="0" To="360" Duration="0:0:1"/>
        </Storyboard>
    </Window.Resources>

    <Border Background="#E60A0406"
            BorderBrush="#FFD700"
            BorderThickness="2"
            CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect Color="#FFD700" BlurRadius="30" ShadowDepth="0" Opacity="0.4"/>
        </Border.Effect>

        <Grid>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Logo nhỏ -->
                <Border Width="60" Height="60"
                        Margin="0,0,0,24"
                        CornerRadius="12"
                        BorderBrush="#FFD700"
                        BorderThickness="2">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1A1015" Offset="0"/>
                            <GradientStop Color="#0A0406" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Image Source="asset/Logo/joli-film-logo.png" Stretch="Uniform" Margin="6"/>
                </Border>

                <!-- Spinner -->
                <Grid Width="70" Height="70" Margin="0,0,0,20">
                    <Ellipse Stroke="#4A3520" StrokeThickness="5" Opacity="0.4"/>
                    <Ellipse x:Name="LoadingSpinner"
                             Stroke="#FFD700"
                             StrokeThickness="5"
                             StrokeDashArray="1.5 1"
                             StrokeStartLineCap="Round"
                             StrokeEndLineCap="Round"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform Angle="0"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#FFD700" BlurRadius="15" ShadowDepth="0" Opacity="0.6"/>
                        </Ellipse.Effect>
                    </Ellipse>
                </Grid>

                <!-- Text -->
                <TextBlock Text="Đang khởi tạo..."
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#FFD700"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="StatusText"
                           Text="Đang kết nối camera..."
                           FontSize="12"
                           Foreground="#C9B896"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>

        <Border.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard Storyboard="{StaticResource LoadingRotation}"/>
            </EventTrigger>
        </Border.Triggers>
    </Border>
</Window>
