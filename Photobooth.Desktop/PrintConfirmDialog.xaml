<Window x:Class="Photobooth.Desktop.PrintConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Joli Films - Xác nhận in ấn"
        Icon="pack://application:,,,/asset/Logo/joli-film-logo.png"
        Width="720"
        Height="580"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="#170507"
        FontFamily="Bahnschrift">

    <Window.Resources>
        <LinearGradientBrush x:Key="BgGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#170507" Offset="0.00" />
            <GradientStop Color="#2A090C" Offset="0.52" />
            <GradientStop Color="#3A0D10" Offset="1.00" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="GoldGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#C4974F" Offset="0.00" />
            <GradientStop Color="#E8C97A" Offset="0.50" />
            <GradientStop Color="#D4AA5C" Offset="1.00" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="GoldGradientDark" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#8A6236" Offset="0.00" />
            <GradientStop Color="#B98A4A" Offset="1.00" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="RedGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#8B1A1A" Offset="0.00" />
            <GradientStop Color="#C0392B" Offset="0.50" />
            <GradientStop Color="#8B1A1A" Offset="1.00" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="GreenGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#1E7E34" Offset="0.00" />
            <GradientStop Color="#2ECC71" Offset="0.50" />
            <GradientStop Color="#1E7E34" Offset="1.00" />
        </LinearGradientBrush>

        <!-- Nút DỪNG LẠI - đỏ bự -->
        <Style x:Key="RedButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource RedGradient}" />
            <Setter Property="BorderBrush" Value="#5C1010" />
            <Setter Property="BorderThickness" Value="3" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="28,16">
                            <Border.Effect>
                                <DropShadowEffect Color="#5C1010" BlurRadius="10" ShadowDepth="3" Opacity="0.6" Direction="270" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.88" />
                                <Setter TargetName="Root" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#FF4444" BlurRadius="16" ShadowDepth="4" Opacity="0.7" Direction="270" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.75" />
                                <Setter TargetName="Root" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#5C1010" BlurRadius="5" ShadowDepth="1" Opacity="0.5" Direction="270" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Nút XÁC NHẬN IN - vàng bự -->
        <Style x:Key="GoldButton" TargetType="Button">
            <Setter Property="Foreground" Value="#170507" />
            <Setter Property="Background" Value="{StaticResource GoldGradient}" />
            <Setter Property="BorderBrush" Value="#8A6236" />
            <Setter Property="BorderThickness" Value="3" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="28,16">
                            <Border.Effect>
                                <DropShadowEffect Color="#8A6236" BlurRadius="10" ShadowDepth="3" Opacity="0.6" Direction="270" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92" />
                                <Setter TargetName="Root" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#E8C97A" BlurRadius="18" ShadowDepth="4" Opacity="0.7" Direction="270" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.78" />
                                <Setter TargetName="Root" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#8A6236" BlurRadius="5" ShadowDepth="1" Opacity="0.5" Direction="270" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Nút In ngay - xanh bự -->
        <Style x:Key="GreenButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource GreenGradient}" />
            <Setter Property="BorderBrush" Value="#145A26" />
            <Setter Property="BorderThickness" Value="3" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="28,16">
                            <Border.Effect>
                                <DropShadowEffect Color="#145A26" BlurRadius="10" ShadowDepth="3" Opacity="0.6" Direction="270" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.90" />
                                <Setter TargetName="Root" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#2ECC71" BlurRadius="18" ShadowDepth="4" Opacity="0.7" Direction="270" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.75" />
                                <Setter TargetName="Root" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#145A26" BlurRadius="5" ShadowDepth="1" Opacity="0.5" Direction="270" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BgGradient}">
        <Border Background="#2A0F12"
                BorderBrush="#7A4730"
                BorderThickness="2"
                Margin="20"
                Padding="28">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock Text="SELF BOOTH HANDI"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#E8C97A"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="34 ngõ 58 Đào Tấn, Ba Đình, Hà Nội"
                               FontSize="11"
                               Foreground="#D8BFA1"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0" />
                </StackPanel>

                <!-- Separator -->
                <Rectangle Grid.Row="1" Height="2" Fill="#5A241A" Margin="0,8,0,16" HorizontalAlignment="Stretch" />

                <!-- Preview Image -->
                <Border Grid.Row="2"
                        Background="#1A080A"
                        BorderBrush="#7A4730"
                        BorderThickness="2"
                        ClipToBounds="True"
                        Margin="0,0,0,16">
                    <Image x:Name="PreviewImage"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Border>

                <!-- Buttons Row -->
                <StackPanel Grid.Row="3">
                    <!-- Status text -->
                    <TextBlock x:Name="PhotoCountText"
                               Text="Chuẩn bị in 4 ảnh"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#E8C97A"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16" />

                    <!-- Buttons -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- DỪNG LẠI -->
                        <Button Grid.Column="0"
                                Style="{StaticResource RedButton}"
                                Content="DỪNG LẠI"
                                Click="Stop_Click" />

                        <!-- XÁC NHẬN IN -->
                        <Button Grid.Column="2"
                                Style="{StaticResource GoldButton}"
                                Content="XÁC NHẬN IN"
                                Click="ConfirmPrint_Click"
                                IsDefault="True" />

                        <!-- In ngay -->
                        <Button Grid.Column="4"
                                Style="{StaticResource GreenButton}"
                                Content="In ngay"
                                Click="PrintNow_Click" />
                    </Grid>

                    <!-- Hint -->
                    <TextBlock Text="Dừng lại: hủy in, xem lại. Xác nhận: đợi máy in. In ngay: in ngay lập tức."
                               FontSize="10"
                               Foreground="#8A6040"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap"
                               TextAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
